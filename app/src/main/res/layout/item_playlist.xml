<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:paddingTop="0dp"
    android:paddingBottom="0dp"
    android:padding="0dp"
    android:layout_margin="0dp"
    android:background="?android:attr/selectableItemBackground">

    <!-- Song name -->
    <com.google.android.material.textview.MaterialTextView
        android:id="@+id/tv_file_name"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginEnd="8dp"
        android:layout_marginTop="4dp"
        android:layout_marginBottom="4dp"
        android:textSize="15sp"
        android:textStyle="normal"
        android:maxLines="1"
        android:ellipsize="end"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toStartOf="@id/tv_status" />

    <!-- Status / Position -->
    <com.google.android.material.textview.MaterialTextView
        android:id="@+id/tv_status"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="0dp"
        android:layout_marginBottom="0dp"
        android:textSize="13sp"
        android:textColor="?attr/colorSecondary"
        android:visibility="gone"
        app:layout_constraintTop_toTopOf="@id/tv_file_name"
        app:layout_constraintBottom_toBottomOf="@id/tv_file_name"
        app:layout_constraintEnd_toStartOf="@+id/btn_move_up" />

    <!-- Position (00:00 / 04:20) -->
    <com.google.android.material.textview.MaterialTextView
        android:id="@+id/tv_position"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"

        android:textSize="12sp"
        android:textColor="#88FFFFFF"
        android:visibility="gone"
        android:layout_marginTop="0dp"
        android:layout_marginBottom="0dp"
        app:layout_constraintTop_toBottomOf="@id/tv_file_name"
        app:layout_constraintStart_toStartOf="@id/tv_file_name" />

    <!-- Move Up -->
    <ImageButton
        android:id="@+id/btn_move_up"
        android:layout_width="36dp"
        android:layout_height="36dp"
        android:src="@drawable/ic_menu_up"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:contentDescription="Move up"
        android:padding="6dp"
        android:layout_marginTop="0dp"
        android:layout_marginBottom="0dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toStartOf="@id/btn_move_down" />

    <!-- Move Down -->
    <ImageButton
        android:id="@+id/btn_move_down"
        android:layout_width="36dp"
        android:layout_height="36dp"
        android:src="@drawable/ic_menu_down"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:contentDescription="Move down"
        android:padding="6dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toStartOf="@+id/btn_delete" />

    <!-- Delete -->
    <ImageButton
        android:id="@+id/btn_delete"
        android:layout_width="44dp"
        android:layout_height="44dp"
        android:src="@android:drawable/ic_menu_delete"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:contentDescription="Delete track"
        android:padding="8dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>